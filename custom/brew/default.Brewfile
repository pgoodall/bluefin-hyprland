# Default Brewfile for bluefin-hyprland
# Uncomment packages you want to install, or add your own.
# Users install via: ujust install-default-apps
brew "bat"          # Better version of cat
brew "netcat"       # Often needed - i.e. `nc -vz my-server 22`
brew "nmap"         # Handy network mapping tool

# Install 1Password CLI via cask
cask "1password-cli"